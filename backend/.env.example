# Copy this file to .env and fill in real values.
# Any store left blank will just make that one store report an error in the
# app — the rest still work.

# Kroger Product API (https://developer.kroger.com) — client_credentials app
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Aldi, Trader Joe's, and Sprouts need no configuration — each resolves the
# nearest real store directly from the shopper's ZIP code at search time
# (see backend/src/services/locators/).

# Port the server listens on
PORT=3001
